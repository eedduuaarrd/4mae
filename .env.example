# Base path (només si el deploy NO és a l'arrel del domini)
# Vercel / domini propi: no cal (usa /)
# GitHub Pages: npm run build:pages  o  VITE_BASE_PATH=/4mae/

# Endpoint opcional per rebre emails per correu (Formspree)
# VITE_WAITLIST_ENDPOINT=https://formspree.io/f/xxxxxxxx

# Vercel: clau per descarregar waitlist.csv (GET /api/waitlist, capçalera x-admin-key)
# WAITLIST_ADMIN_SECRET=canvia-aixo
